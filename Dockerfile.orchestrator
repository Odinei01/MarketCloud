FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/orchestrator ./cmd/query-orchestrator

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /bin/orchestrator /bin/orchestrator
EXPOSE 8092
ENTRYPOINT ["/bin/orchestrator"]
